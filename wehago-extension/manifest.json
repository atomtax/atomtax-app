{
  "manifest_version": 3,
  "name": "아톰베이스 위하고 수집기",
  "version": "1.0.0",
  "description": "위하고 화면 데이터를 아톰베이스로 안전하게 동기화 (읽기 전용)",
  "permissions": ["storage"],
  "host_permissions": [
    "https://*.wehago.com/*",
    "https://atomtax-app.vercel.app/*"
  ],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["https://*.wehago.com/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "world": "ISOLATED",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["interceptor.js"],
      "matches": ["https://*.wehago.com/*"]
    }
  ],
  "action": { "default_popup": "popup.html" },
  "icons": { "16": "icons/16.png", "48": "icons/48.png", "128": "icons/128.png" },
  "key": ""
}
